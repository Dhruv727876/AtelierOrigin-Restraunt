# Atelier Origine - Template Environment Variables
# Copy this file to .env.local and fill in the values below

# SEO & Analytics
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend Services (If you are connecting the reservation form)
# RESEND_API_KEY=re_123456789
# CONTACT_EMAIL=reservations@yourdomain.com

# Map Integrations (Optional)
# NEXT_PUBLIC_MAPBOX_TOKEN=pk....

# CMS Integrations (If you plan to switch data/site.ts to a headless CMS)
# SANITY_PROJECT_ID=...
# STRAPI_API_URL=...
